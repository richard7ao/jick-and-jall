rules_version = '2';

// Default-deny Firestore rules. Application writes go through server-side
// repositories using the Admin SDK (which bypasses these rules); direct client
// access is restricted to an owner reading their own documents.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // A user may read only their own identity document. All client writes are
    // denied; identity is created/updated server-side only.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Owner-readable profile documents keyed by uid. Writes are server-only.
    match /creatorProfiles/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /brandProfiles/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Everything else is denied by default (waitlist, invitations, campaigns,
    // matches, deals, messages, voiceSessions are server-mediated in v1).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
