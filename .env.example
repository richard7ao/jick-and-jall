# Jick & Jall — example environment.
# Copy to `.env` (which must stay untracked) and fill in real values locally.
# Never commit real secrets. `pnpm bootstrap:check` validates presence, not values.

# --- Coordination -----------------------------------------------------------
# Immutable per-machine agent identity. Exactly "agent-1" or "agent-2".
JJ_AGENT_ID=agent-2

# --- Superlinked Inference Engine (primary generation/embedding provider) ----
SUPERLINKED_BASE_URL=https://your-superlinked-host.example.com:8080
SUPERLINKED_API_KEY=SL-000000000000000000000000000000
SUPERLINKED_CHAT_MODEL=
SUPERLINKED_EMBEDDING_MODEL=
SUPERLINKED_MACHINE_PROFILE=

# --- ElevenLabs Conversational AI (voice onboarding; dev/manual QA only) -----
ELEVENLABS_API_KEY=

# --- Firebase (Auth, Firestore, private Storage) ----------------------------
# Emulator project id is "demo-jj"; leave admin credentials empty for emulator.
FIREBASE_PROJECT_ID=demo-jj
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-jj
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# --- Firebase-managed Google sign-in ----------------------------------------
GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe (test mode only; live payout/refund remain disabled) ------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
